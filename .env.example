# =============================================================
#  Cassandra Time Series ML Pipeline - Environment Variables
# =============================================================

# Cassandra Connection
CASSANDRA_HOSTS=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=timeseries
CASSANDRA_USERNAME=
CASSANDRA_PASSWORD=
CASSANDRA_SSL=false

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_EXECUTOR_MEMORY=4g

# Application
LOG_LEVEL=INFO
